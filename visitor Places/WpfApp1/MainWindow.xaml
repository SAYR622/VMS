<Window x:Class="HeritageSiteApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visitor Interface" Height="650" Width="1100" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="Border">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextElement.Foreground" Value="#DDDDDD"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3D4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedMenuItemStyle" TargetType="Border" BasedOn="{StaticResource MenuItemStyle}">
            <Setter Property="Background" Value="#A8C4E5"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#2B2D3A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20,30,20,10">
                <TextBlock Text="VISITOR INTERFACE" Foreground="White" FontSize="22" FontWeight="Light" Margin="0,0,0,30"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="40" Height="40" CornerRadius="20" Background="#E0E0E0" HorizontalAlignment="Left">
                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Welcome" Foreground="#BBBBBB" FontSize="12"/>
                        <TextBlock Text="Visitor #1025" Foreground="White" FontSize="16"/>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="#444" Margin="0,10,0,20"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10,0">
                <Border Style="{StaticResource MenuItemStyle}">
                    <TextBlock Text="🏠  Dashboard" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource MenuItemStyle}">
                    <TextBlock Text="📅  Visit Plan" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource SelectedMenuItemStyle}">
                    <TextBlock Text="📍  Visited Places" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource MenuItemStyle}">
                    <TextBlock Text="ℹ️  Heritage Information" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource MenuItemStyle}">
                    <TextBlock Text="❗  Rules &amp; Guidelines" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource MenuItemStyle}">
                    <TextBlock Text="👤  Profile" FontSize="16"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="20,20,20,30">
                <Border Height="1" Background="#444" Margin="0,0,0,20"/>
                <TextBlock Text="SITE STATUS" Foreground="White" FontSize="16"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="Status: " Foreground="#BBBBBB" FontSize="14"/>
                    <TextBlock Text="Online" Foreground="#6C9A8B" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#F4F0F4">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#E5E5E8">
                <TextBlock Text="Cultural Heritage Site Management System" VerticalAlignment="Center" Margin="20,0" FontSize="16" Foreground="#444"/>
                <TextBlock Text="Thursday, July 12, 2026, 1:30 PM" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="20,0" FontSize="14" Foreground="#333"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="30">
                <TextBlock Text="VISITED PLACES" FontSize="32" FontWeight="Bold" Foreground="#333340" Margin="0,0,0,5"/>
                <TextBlock Text="Welcome, Visitor #1025" FontSize="18" Foreground="#555" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="COMPLETED LOCATIONS" FontSize="18" Margin="0,0,0,20"/>

                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1" FontSize="18" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" Background="#EAEAEA">
                                    <TextBlock Text="🏛️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="Museum" FontSize="18"/>
                                    <TextBlock Text="Visited: Friday, July 11, 2026, 10:15 AM" FontSize="14" Foreground="#666"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="2" FontSize="18" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" Background="#EAEAEA">
                                    <TextBlock Text="⛩️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="Temple Complex" FontSize="18"/>
                                    <TextBlock Text="Visited: Friday, July 11, 2026, 1:30 PM" FontSize="14" Foreground="#666"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="3" FontSize="18" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" Background="#EAEAEA">
                                    <TextBlock Text="🛁" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="Ancient Bath Site" FontSize="18"/>
                                    <TextBlock Text="Visited: Friday, July 11, 2026, 3:45 PM" FontSize="14" Foreground="#666"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="PROGRESS SUMMARY" FontSize="18" Margin="0,0,0,20"/>

                            <Grid Width="200" Height="200" HorizontalAlignment="Center" Margin="0,10,0,30">
                                <Path Fill="#D9D9D9" Data="M 100,0 A 100,100 0 0,0 100,200 Z"/>
                                <Path Fill="#4785C8" Data="M 100,200 A 100,100 0 0,0 100,0 Z"/>

                                <TextBlock Text="50%" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0" FontSize="18" Foreground="Black"/>
                                <TextBlock Text="50%" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,30,0" FontSize="18" Foreground="White"/>
                            </Grid>

                            <StackPanel Margin="10,0,0,20">
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="12" Height="12" Fill="#4785C8" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="VISITED: 3 locations&#x0a;(Museum, Temple, Bath Site)" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                                </Grid>
                                <Grid Margin="0,10,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="12" Height="12" Fill="#D9D9D9" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Column="1" Text="REMAINING: 3 Locations&#x0a;(Garden, Gift Shop, +1 other)" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                                </Grid>
                            </StackPanel>

                            <Border Height="1" Background="#E0E0E0" Margin="0,10"/>

                            <TextBlock Text="Total Locations: 6 | Progress: 50% (3/6)" HorizontalAlignment="Center" FontSize="14" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
