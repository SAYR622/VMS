<Window x:Class="TourGuideInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tour Guide Dashboard"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F1EB">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#222433" Offset="0"/>
                    <GradientStop Color="#3E3A4F" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="25">

                    <TextBlock Text="TOUR GUIDE INTERFACE"
                               FontSize="36"
                               Foreground="White"
                               Margin="0,0,0,40"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,30">

                        <Ellipse Width="80"
                                 Height="80"
                                 Fill="#E8DFD1"/>

                        <StackPanel Margin="15,10,0,0">

                            <TextBlock Text="Welcome"
                                       FontSize="22"
                                       Foreground="White"/>

                            <TextBlock Text="Guide #4503"
                                       FontSize="22"
                                       Foreground="White"/>

                        </StackPanel>

                    </StackPanel>

                    <Separator Margin="0,0,0,20"/>

                    <Button Content="🏠  My Dashboard"
                            Height="50"
                            FontSize="22"
                            Background="#E7D18A"
                            BorderThickness="0"
                            Margin="0,5"/>

                    <Button Content="👥  Assigned Visitors"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="📅  Tour Schedule"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="ℹ  Artifact Information"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="🚨  Lost Visitor Alerts"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <TextBlock Text="GUIDE MANAGEMENT &amp; METRICS"
                               Margin="0,30,0,15"
                               FontSize="24"
                               Foreground="White"/>

                    <Button Content="Gender Data"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="Guide Availability"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="Experience Record"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="Performance Summary"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Button Content="Guide Dashboard"
                            Height="45"
                            FontSize="20"
                            Margin="0,5"/>

                    <Separator Margin="0,25"/>

                    <TextBlock Text="SITE STATUS"
                               FontSize="26"
                               Foreground="White"/>

                    <TextBlock Text="Status: Online"
                               FontSize="20"
                               Foreground="#90EE90"/>

                </StackPanel>

            </ScrollViewer>
        </Border>

        
        <Grid Grid.Column="1" Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0"
                    Background="#DDDDDD"
                    CornerRadius="5">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Cultural Heritage Site Management System"
                               FontSize="30"
                               VerticalAlignment="Center"
                               Margin="20,0"/>

                    <TextBlock Grid.Column="1"
                               Text="Tuesday, October 24, 2024"
                               FontSize="22"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                </Grid>

            </Border>

            
            <StackPanel Grid.Row="1"
                        Margin="15">

                <TextBlock Text="MY GUIDE DASHBOARD"
                           FontSize="55"
                           FontWeight="Bold"
                           Foreground="#B59A58"/>

                <TextBlock Text="Welcome, Guide #4503"
                           FontSize="24"/>

            </StackPanel>

            
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="PERSONAL PERFORMANCE OVERVIEW"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Current Rating: 4.9 / 5"
                                   FontSize="20"
                                   Margin="0,15,0,0"/>

                        <TextBlock Text="Average Group Size: 17.5"
                                   FontSize="20"/>

                        <TextBlock Text="On-Time Departure Rate: 99.1%"
                                   FontSize="20"/>

                    </StackPanel>

                </Border>

                
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="MY ASSIGNED TOURS TODAY"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="09:30 AM - Group #1105 (20 pax)"
                                   FontSize="20"
                                   Margin="0,15,0,0"/>

                        <TextBlock Text="Main Temple Tour"
                                   FontSize="18"/>

                        <TextBlock Text="13:30 PM - Group #1112 (15 pax)"
                                   FontSize="20"
                                   Margin="0,15,0,0"/>

                        <TextBlock Text="Palace Ruins &amp; Museum"
                                   FontSize="18"/>

                        <TextBlock Text="Total Visitors Today: 35"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,15,0,0"/>

                    </StackPanel>

                </Border>

                
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="180"
                                Height="220"
                                CornerRadius="10"
                                Background="#D9D9D9"/>

                        <StackPanel Grid.Column="1">

                            <TextBlock Text="MY PROFILE DETAILS"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="Name: Guide Name"
                                       FontSize="18"/>

                            <TextBlock Text="ID: 4503"
                                       FontSize="18"/>

                            <TextBlock Text="Level: Certified Senior Guide"
                                       FontSize="18"/>

                            <TextBlock Text="Primary Language: English"
                                       FontSize="18"/>

                            <TextBlock Text="Second Language: Mandarin"
                                       FontSize="18"/>

                            <TextBlock Text="Specialization: Asian Art &amp; History"
                                       FontSize="18"/>

                        </StackPanel>

                    </Grid>

                </Border>

                
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="AVAILABILITY &amp; UPCOMING"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="OCT 25 : RDO / Not Scheduled"
                                   FontSize="20"
                                   Margin="0,20,0,0"/>

                        <TextBlock Text="OCT 26 : 09:00 - 17:00 Available"
                                   FontSize="20"/>

                        <TextBlock Text="OCT 27 : 09:00 - 17:00 Available"
                                   FontSize="20"/>

                        <TextBlock Text="OCT 28 : Assigned Group #120"
                                   FontSize="20"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>
</Window>
